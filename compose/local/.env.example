# PostgreSQL
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments
DATABASE__DSN=postgresql+asyncpg://payments:payments@payment-db:5432/payments

# RabbitMQ
RABBITMQ_DEFAULT_USER=payments
RABBITMQ_DEFAULT_PASS=payments
RABBIT__HOST=rabbitmq
RABBIT__PORT=5672
RABBIT__USERNAME=payments
RABBIT__PASSWORD=payments
RABBIT__VHOST=/

# Redis (TaskIQ)
TASK_BROKER__DSN=redis://redis:6379/1

# API
API_KEY=dev-api-key
LOGGING_LEVEL=INFO

# Outbox worker
OUTBOX_WORKER__RUN=True
OUTBOX_WORKER__CRON_EXPRESSION=*/1 * * * *

# Payment consumer
PAYMENT_CONSUMER__QUEUE_RETRY_TTL_SECONDS=30
PAYMENT_CONSUMER__MAX_QUEUE_DELIVERY_ATTEMPTS=5
PAYMENT_CONSUMER__PREFETCH_COUNT=10
